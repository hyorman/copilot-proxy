{
  "name": "@hyorman/copilot-proxy-cli",
  "version": "1.0.2",
  "description": "OpenAI-compatible proxy server for GitHub Copilot, powered by the Copilot SDK",
  "type": "module",
  "main": "out/main.js",
  "bin": {
    "copilot-proxy": "out/main.js"
  },
  "license": "MIT",
  "author": "hyorman",
  "repository": {
    "type": "git",
    "url": "https://github.com/hyorman/copilot-proxy.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "copilot",
    "openai",
    "proxy",
    "github",
    "cli",
